{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Vaquill AI",
  "description": "Legal research platform and case law API. Search 20M+ cases, resolve citations, and integrate legal data into your product.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "https://vaquill.ai"
  },
  "favicon": "/favicon.png",
  "seo": {
    "indexing": "all",
    "metatags": {
      "canonical": "https://vaquill.ai/docs",
      "og:site_name": "Vaquill AI Docs",
      "og:image": "/images/main-ui.jpeg",
      "og:description": "Legal research platform and case law API. Search 20M+ cases, resolve citations, and integrate legal data into your product.",
      "og:locale": "en_US",
      "twitter:card": "summary_large_image",
      "twitter:site": "@vaquill"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "browser",
          "href": "https://app.vaquill.ai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "guides/document-search",
              "guides/case-law-research",
              "guides/contract-review",
              "guides/citations"
            ]
          },
          {
            "group": "Features",
            "icon": "book-open",
            "pages": [
              "guides/agent-mode",
              "guides/skills",
              "guides/memories",
              "guides/mcp-client",
              "guides/legal-tools",
              "guides/matters-workspaces"
            ]
          },
          {
            "group": "Developers",
            "icon": "code",
            "pages": [
              "authentication",
              "credits",
              "errors"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": [
              "integrations/mcp",
              "integrations/courtlistener-mcp",
              "integrations/canlii-mcp"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://api.vaquill.ai/external/openapi.json"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@vaquill.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.vaquill.ai"
    }
  },
  "api": {
    "openapi": "https://api.vaquill.ai/external/openapi.json",
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "mdx": {
      "auth": {
        "method": "bearer",
        "name": "Authorization"
      },
      "server": "https://api.vaquill.ai"
    },
    "examples": {
      "languages": ["bash", "python", "javascript", "go"],
      "defaults": "required",
      "prefill": true
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/vaquill/",
      "youtube": "https://www.youtube.com/@vaquill",
      "slack": "https://join.slack.com/t/vaquillaicommunity/shared_invite/zt-3qxv4mtxg-64mtkVe2PxodDMwKGPfvMQ",
      "github": "https://github.com/Vaquill-AI"
    },
    "links": [
      {
        "header": "Quick Links",
        "items": [
          { "label": "Dashboard", "href": "https://app.vaquill.ai" },
          { "label": "Pricing", "href": "https://vaquill.ai/#pricing" },
          { "label": "About", "href": "https://vaquill.ai/about" },
          { "label": "Contact", "href": "https://vaquill.ai/contact" },
          { "label": "Brand Assets", "href": "https://vaquill.ai/brand" },
          { "label": "API Reference", "href": "/api-reference/ask/ask-a-legal-question" },
          { "label": "Postman Collection", "href": "https://www.postman.com/priyansh-57bdb803-2033693/vaquill-ai/collection/52997016-86d6f62d-ef53-4feb-85f4-915ef7a933cb/?action=share&creator=52997016" }
        ]
      },
      {
        "header": "Features",
        "items": [
          { "label": "Agent Mode", "href": "https://vaquill.ai/features/agent-mode" },
          { "label": "Skills", "href": "https://vaquill.ai/features/skills" },
          { "label": "Memories", "href": "https://vaquill.ai/features/memories" },
          { "label": "AI Legal Research", "href": "https://vaquill.ai/features/legal-research" },
          { "label": "Compliance Check", "href": "https://vaquill.ai/features/compliance-check" },
          { "label": "Chronology Builder", "href": "https://vaquill.ai/features/chronology-builder" }
        ]
      },
      {
        "header": "Use Cases",
        "items": [
          { "label": "Litigation Lawyers", "href": "https://vaquill.ai/use-case/litigation-lawyers" },
          { "label": "Corporate Lawyers", "href": "https://vaquill.ai/use-case/corporate-lawyers" },
          { "label": "Law Firms", "href": "https://vaquill.ai/use-case/law-firms" },
          { "label": "Legal Tech Developers", "href": "https://vaquill.ai/use-case/legal-tech-developers" },
          { "label": "Solo Practitioners", "href": "https://vaquill.ai/use-case/solo-practitioners" }
        ]
      },
      {
        "header": "Legal",
        "items": [
          { "label": "Privacy Policy", "href": "https://vaquill.ai/privacy" },
          { "label": "Terms of Service", "href": "https://vaquill.ai/terms" },
          { "label": "Cookie Policy", "href": "https://vaquill.ai/cookies" },
          { "label": "Refund Policy", "href": "https://vaquill.ai/refund-policy" }
        ]
      }
    ]
  },
  "redirects": [],
  "appearance": {
    "default": "light",
    "strict": true
  }
}
