{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Vaquill AI",
  "description": "Documentation and API reference for Indian legal research and citation intelligence.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "https://vaquill.ai"
  },
  "favicon": "/favicon.png",
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:site_name": "Vaquill AI Docs",
      "og:image": "/images/main-ui.jpeg",
      "og:description": "Documentation and API reference for Indian legal research and citation intelligence.",
      "og:locale": "en_US",
      "twitter:card": "summary_large_image",
      "twitter:site": "@vaquill"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "browser",
          "href": "https://app.vaquill.ai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "guides/document-search",
              "guides/case-law-research",
              "guides/contract-review",
              "guides/citations"
            ]
          },
          {
            "group": "Features",
            "icon": "book-open",
            "pages": [
              "guides/legal-tools",
              "guides/matters-workspaces"
            ]
          },
          {
            "group": "Developers",
            "icon": "code",
            "pages": [
              "authentication",
              "credits",
              "errors"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://api.vaquill.ai/external/openapi.json"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@vaquill.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.vaquill.ai"
    }
  },
  "api": {
    "openapi": "https://api.vaquill.ai/external/openapi.json",
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "mdx": {
      "auth": {
        "method": "bearer",
        "name": "Authorization"
      },
      "server": "https://api.vaquill.ai"
    },
    "examples": {
      "languages": ["bash", "python", "javascript", "go"],
      "defaults": "required",
      "prefill": true
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "footer": {
    "socials": {
      "x": "https://x.com/vaquill",
      "github": "https://github.com/vaquill",
      "linkedin": "https://linkedin.com/company/vaquill"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Dashboard", "href": "https://app.vaquill.ai" },
          { "label": "Pricing", "href": "https://vaquill.ai/#pricing" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "API Reference", "href": "/api-reference" },
          { "label": "Authentication", "href": "/authentication" },
          { "label": "Credits", "href": "/credits" }
        ]
      },
      {
        "header": "Legal",
        "items": [
          { "label": "Terms of Service", "href": "https://www.vaquill.ai/terms" },
          { "label": "Privacy Policy", "href": "https://www.vaquill.ai/privacy" }
        ]
      }
    ]
  },
  "redirects": [],
  "appearance": {
    "default": "light",
    "strict": true
  }
}
